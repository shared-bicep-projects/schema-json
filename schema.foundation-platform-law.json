{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ARM Template Parameters - iac-bicep-foundation-platform-law (rg-scope)",
  "type": "object",
  "required": ["$schema", "contentVersion", "parameters"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "contentVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "parameters": {
      "type": "object",
      "required": ["location"],
      "additionalProperties": false,
      "properties": {
        "subscriptionGuid": {
          "type": "object",
          "required": ["value"],
          "properties": {
            "value": {
              "type": "string",
              "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
            }
          }
        },
        "resourceGroupName": {
          "type": "object",
          "required": ["value"],
          "properties": {
            "value": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "workspaceName": {
          "type": "object",
          "required": ["value"],
          "properties": {
            "value": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "location": {
          "type": "object",
          "required": ["value"],
          "properties": {
            "value": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "retentionInDays": {
          "type": "object",
          "required": ["value"],
          "properties": {
            "value": {
              "type": "integer",
              "minimum": 30,
              "maximum": 730
            }
          }
        },
        "dailyQuotaGb": {
          "type": "object",
          "required": ["value"],
          "properties": {
            "value": {
              "type": "integer",
              "minimum": -1
            }
          }
        },
        "tags": {
          "type": "object",
          "required": ["value"],
          "properties": {
            "value": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
